generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  role         String    @default("USER")
  avatar       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  companies    Company[]
}

model Company {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  gstNumber  String?
  website    String?
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  image       String?
  price       Float
  status      String        @default("ACTIVE")
  company     Company       @relation(fields: [companyId], references: [id])
  companyId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
